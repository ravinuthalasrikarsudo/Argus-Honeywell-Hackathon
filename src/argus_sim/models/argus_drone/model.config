<?xml version="1.0"?>
<model>
  <name>argus_drone</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>

  <author>
    <name>vittal</name>
    <email>vittal.muku@gmail.com</email>
  </author>

  <description>
    ARGUS Day-1 kinematic stereo/IMU VIO drone. Forward-looking (+X) stereo pair
    (0.12 m baseline, 2x 720p ogre2 cameras), 250 Hz IMU, ground-truth pose
    publisher, and a VelocityControl cmd_vel interface. Gravity-disabled and
    velocity-driven: no aerodynamics/thrust model (kinematic foundation for VIO).
  </description>
</model>
